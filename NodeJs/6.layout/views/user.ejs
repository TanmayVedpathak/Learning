<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>User Detail</title>
    </head>

    <body>
        <% if (status=='failure' ) { %>
        <h1>No user data found</h1>
        <% } else { %>
        <h1><%= data.name %></h1>
        <p>Email: <%= data.email %></p>
        <p>Active: <%= data.isActive ? 'TRUE' : 'FALSE' %></p>
        <% } %>
    </body>
</html>
