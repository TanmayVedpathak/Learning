<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Users List</title>
    </head>
    <body>
        <h1>List of user</h1>

        <% data.forEach(user => { %>
        <h2><%= user.name %></h2>
        <p>Email: <%= user.email %></p>
        <p>Active: <%= user.isActive ? 'TRUE' : 'FALSE' %></p>
        <% }); %>
    </body>
</html>
